# AVO per-run artifacts.
# Keep tracked: planning markdown, SUMMARY/COMPARISON, per-step result.md /
# hypothesis.md / verify_fp8.json / diff.patch / probe scripts.
# Exclude: binary profiling captures + raw logs (regenerable, ~MB-GB each).

# Binary profiling captures (any path under runs/)
runs/**/*.nsys-rep
runs/**/*.ncu-rep
runs/**/*.sqlite

# Raw stats / log dumps that are regenerable
runs/**/*.txt
runs/**/pytest.log
runs/**/smoke_*.log

# Old-style version-folder layout (superseded by tracks/)
runs/v*/

# Live process state: not source.
logs/
checkpoints/
scratchpads/
workflow-alert.md
